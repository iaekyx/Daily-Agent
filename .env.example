# Copy this file to .env and fill in your own keys.
# Do not commit the real .env file.

# Choose one provider. If GEMINI_API_KEY is set, the app uses Gemini first.
GEMINI_API_KEY=
DASHSCOPE_API_KEY=

# Optional model override.
MODEL_ID=

# Optional GitHub token for higher GitHub API rate limits.
GITHUB_TOKEN=

# Optional CORS origins for the FastAPI frontend.
DAILY_AGENT_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

